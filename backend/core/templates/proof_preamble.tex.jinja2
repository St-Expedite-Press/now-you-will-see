%# proof_preamble.tex.jinja2
%# Shared LaTeX preamble for typeset proof-draft builds.
%# \input{preamble} from the master; \input{../preamble} for standalone poem compile.
%# Do NOT include \documentclass or \begin{document} — this is a fragment.
\BLOCK{set rc = config.render_config or {}}

\usepackage{fontspec}
\usepackage{microtype}
\usepackage{etoolbox}
\usepackage{environ}

% Body font (set via render_config.mainfont; default Crimson Pro)
\setmainfont{\VAR{rc.get("mainfont") or "Crimson Pro"}}[
  Ligatures = TeX,
  Numbers   = OldStyle,
]

% Display/heading font: IM FELL English SC (already a small-caps design)
\newfontfamily\headingfont{IM FELL English SC}[
  Ligatures = TeX,
]

% Ornament font: IM FELL FLOWERS 2 (press bird and decorative ornaments)
\newfontfamily\ornamentfont{IM FELL FLOWERS 2}[
  Ligatures = TeX,
]

\usepackage{polyglossia}
\setdefaultlanguage{\VAR{config.language}}

\usepackage[
  paperwidth=\VAR{rc.get("paperwidth") or "6in"},
  paperheight=\VAR{rc.get("paperheight") or "9in"},
  top=\VAR{rc.get("top_margin") or "0.875in"},
  bottom=\VAR{rc.get("bottom_margin") or "0.875in"},
  inner=\VAR{rc.get("inner_margin") or "1in"},
  outer=\VAR{rc.get("outer_margin") or "0.75in"},
  % No running head (folio-only at foot), so reserve no header band — an empty
  % head height+sep otherwise pushes the text block ~0.5in down every page.  The
  % top margin then measures straight to the text block.  Foot kept inside the
  % bottom margin for the folio.
  headheight=0pt,
  headsep=0pt,
  includefoot,
]{geometry}

%# PDF/X-3 compliance for vendor upload (print-ready only).  Loaded AFTER
%# geometry so pdfx adopts the custom trim instead of forcing letter, and before
%# hyperref (which pdfx pulls in itself).  Metadata comes from <job>.xmpdata.
\BLOCK{if print_ready}
\usepackage[x-3]{pdfx}
\BLOCK{endif}

\usepackage{verse}

% Verse: keep the lines of a stanza together so a page break never splits a
% stanza.  The verse package ends each line with a bare \par (only the starred
% \\* adds \nobreak), so by default a page can break between any two lines.
% Patch its line-break macro to make every break non-breakable; the breakable
% point then survives only at the inter-stanza \vspace between verse environments.
\makeatletter
\patchcmd{\@vscentercr}{\par\@ifstar}{\par\nobreak\@ifstar}{}{}
\makeatother

% Discourage stranding a lone line at the top or bottom of a page, and let pages
% end short rather than stretch verse to fill (poetry sets ragged-bottom).
\widowpenalty=10000
\clubpenalty=10000
\raggedbottom

% Title sink: top-set poems drop this far from the top of the text block so
% titles land in a consistent optical position across spreads.
\newlength{\poemsink}
\setlength{\poemsink}{\VAR{rc.get("title_sink") or "0.06\\textheight"}}

% One-poem-per-page placement, decided by ACTUAL typeset height rather than a
% line-count guess.  The poem (title + body) is set into a box and measured: if
% it fits within \shortpoemlimit it is optically centered on its page;
% otherwise it is top-set from the sink and \unvbox'd so it can flow across
% pages, breaking only between stanzas (the verse \nobreak patch above keeps
% each stanza whole).  \shortpoemlimit is tunable via render_config.short_poem_maxheight.
\newsavebox{\poembox}
\newlength{\shortpoemlimit}
\setlength{\shortpoemlimit}{\VAR{rc.get("short_poem_maxheight") or "0.62\\textheight"}}
% Slack by which a just-too-tall poem may overrun a page (via \enlargethispage)
% to stay whole instead of orphaning a closing line or two.
\newlength{\tgsqueeze}
\setlength{\tgsqueeze}{\VAR{rc.get("page_squeeze") or "3\\baselineskip"}}
% page_mode: one-per-page (default, hardcover) vs flow (softcover — poems pack,
% several short poems per page).  Separator above each poem in flow mode.
\newif\ifflowmode
\BLOCK{if rc.get("page_mode") == "flow"}\flowmodetrue\BLOCK{else}\flowmodefalse\BLOCK{endif}
% Short-poem placement: center the intact poem on its page (default), or top-set
% it from the sink like medium poems (render_config.short_poem_placement: top) so
% every title lands at a consistent height and pages carry no big top-of-page
% band of whitespace.
\newif\ifcentershort
\BLOCK{if rc.get("short_poem_placement") == "top"}\centershortfalse\BLOCK{else}\centershorttrue\BLOCK{endif}
\newlength{\poemsep}
\setlength{\poemsep}{\VAR{rc.get("poem_separation") or "2.2\\baselineskip"}}
% Inter-stanza space — the adjustable gap between stanzas of a poem.  Set
% globally from render_config.stanza_skip; a poem may override it in its own
% front matter (stanza_skip:), scoped to that poem.  Named to avoid the verse
% package's internal \stanzaskip (its within-environment parsep).
\newlength{\interstanzaskip}
\setlength{\interstanzaskip}{\VAR{rc.get("stanza_skip") or "1.2ex"}}
% Each stanza is set in its own \verse (a list), so the list's own \topsep /
% \partopsep / \parsep glue stacks on either side of every stanza and swamps the
% intended \interstanzaskip — making stanza_skip effectively inert and ballooning
% the gaps.  A one-shot zeroing does not hold: every \@setfontsize (e.g. inside
% \poemtitle) restores the default \topsep via \@listI.  So patch \@listI itself
% — the normalsize list defaults — to carry zero top/par glue; \normalsize then
% re-applies the patched version after any size change, and \interstanzaskip
% becomes the ONLY inter-stanza lever.  (Prose still sets its own \parskip.)
\makeatletter
\appto\@listI{\setlength{\topsep}{0pt}\setlength{\partopsep}{0pt}\setlength{\parsep}{0pt}}
\let\@listi\@listI
\makeatother
\newcommand{\tgflattenverse}{\setlength{\topsep}{0pt}\setlength{\partopsep}{0pt}\setlength{\parsep}{0pt}}
\NewEnviron{poemblock}{%
  \setbox\poembox=\vbox{\tgflattenverse\BODY}%
  \edef\tgpoemht{\the\dimexpr\ht\poembox+\dp\poembox\relax}%
  \ifflowmode
    % Flow (softcover): pack poems down the page, each kept whole; a poem that
    % does not fit the remaining space breaks to the next page at the separator.
    \ifdim\tgpoemht<\textheight
      \par\addvspace{\poemsep}\box\poembox
    \else
      \par\addvspace{\poemsep}\unvbox\poembox
    \fi
  \else
    % One-per-page (hardcover): placement by measured height.
    \ifdim\tgpoemht<\shortpoemlimit
      \ifcentershort
        % Short: center the intact poem vertically on its page.
        \vspace*{\fill}\box\poembox\vspace*{\fill}%
      \else
        % Short: top-set from the sink — consistent title height, no top-of-page
        % whitespace band; whitespace collects at the foot instead.
        \vspace*{\poemsink}\box\poembox
      \fi
    \else\ifdim\dimexpr\tgpoemht+\poemsink\relax<\textheight
      % Medium: fits a page with the sink — top-set so titles align across spreads.
      \vspace*{\poemsink}\unvbox\poembox
    \else\ifdim\tgpoemht<\dimexpr\textheight+\tgsqueeze\relax
      % Just over a page: lengthen this page slightly to keep the poem whole.
      \enlargethispage{\tgsqueeze}\unvbox\poembox
    \else
      % Genuinely longer than a page: set flush and flow across pages.
      \unvbox\poembox
    \fi\fi\fi
  \fi
}

% Folio: centered at foot; no running heads (house style: clean body pages)
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\small\thepage}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\small\thepage}%
}

% Blank versos inserted by \cleardoublepage (forcing book/part/notes openings
% onto a recto) must carry NO folio — a page number on an otherwise empty leaf
% is a production defect.  Ship the inserted blank with the empty page style.
\makeatletter
\renewcommand*{\cleardoublepage}{%
  \clearpage
  \if@twoside
    \ifodd\c@page\else
      \null\thispagestyle{empty}\newpage
    \fi
  \fi
}
\makeatother

% Even total page count for print: a book must have an even number of leaves.
% If the last content page leaves the count odd, append one folio-less blank.
\AtEndDocument{%
  \clearpage
  \ifodd\value{page}\else
    \null\thispagestyle{empty}\clearpage
  \fi
}

%# pdfx already loads hyperref in print-ready mode; only configure it then.
\BLOCK{if print_ready}
\hypersetup{hidelinks}
\BLOCK{else}
\usepackage[
  pdftitle={\VAR{config.title}},
  pdfauthor={\VAR{config.author}},
  hidelinks,
]{hyperref}
\BLOCK{endif}

\usepackage{setspace}
\BLOCK{if rc.get("line_spread")}
\linespread{\VAR{rc.get("line_spread")}}\selectfont
\BLOCK{endif}

% TOC: dotted leaders, right-aligned folios
\usepackage{tocloft}
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\setlength{\cftbeforesecskip}{0.3em}

% Keyed notes apparatus (per-volume, generated by render_notes_section).
% No in-text marks: notes are grouped under each poem's title + page reference
% and keyed by line number.  The lemma is set apart from the gloss so the
% apparatus reads as structured entries, not a uniform grey block.
\newcommand{\notessectionhead}[1]{%
  \pagestyle{plain}%
  \chapter*{#1}%
  \addcontentsline{toc}{chapter}{#1}%
  \markboth{}{}%
}
% Per-poem heading: title in the heading face, quiet page reference at the right.
\newcommand{\poemnotehead}[2]{%
  \par\medskip
  \noindent{\headingfont\small #1}\hfill{\footnotesize\textit{p.~\pageref{tg:note:#2}}}%
  \par\nobreak\smallskip
}
% A note: lemma (already styled) then gloss, hanging-indented; and the plain form.
\newcommand{\poemnote}[2]{%
  \par\hangindent=1.5em\hangafter=1\noindent #1\enspace #2\par
}
\newcommand{\poemnoteplain}[1]{%
  \par\hangindent=1.5em\hangafter=1\noindent #1\par
}
% Lemma styles by kind, and the inline accent for line citations within a gloss.
\newcommand{\notelemmacite}[1]{{\itshape #1.}}
\newcommand{\notelemmaform}[1]{{\scshape #1.}}
\newcommand{\noteline}[1]{\textit{#1}}
\newcommand{\notesize}{\small}

% Prose chapter heading (Introduction, Afterword, etc.)
\usepackage{titlesec}
\titleformat{\chapter}[display]
  {}
  {}
  {0pt}
  {\thispagestyle{plain}\vspace*{1.5in}\begin{center}\headingfont\Large}
  [\end{center}\vspace{1.5\baselineskip}]
\titlespacing{\chapter}{0pt}{0pt}{0pt}

% Section heading (within a chapter — used for TOC entries only, not printed)
\titleformat{\section}[hang]{\headingfont\normalsize}{}{0pt}{}
\titlespacing{\section}{0pt}{1.5\baselineskip}{0.5\baselineskip}

% Poem title: IM FELL English SC.  Vertical placement (sink or centering) is
% supplied by the fragment before this is called, so the title itself adds no
% leading space — only the gap between title and first line.
\renewcommand{\poemtitle}[1]{%
  {\noindent\headingfont #1\par}%
  \vspace{0.6\baselineskip}%
  \noindent
}

% Part divider: a full page of its own, forced to a recto, the part label
% centered in the upper-middle of the text block.  The following poem's own
% \clearpage flushes this page (a \clearpage on a fresh page is a no-op, so no
% double blank results).  emptypage keeps the auto-inserted verso clean.
\newcommand{\partdivider}[1]{%
  \cleardoublepage
  \thispagestyle{empty}%
  \addcontentsline{toc}{section}{#1}%
  \null\vspace*{0.32\textheight}%
  \begin{center}%
    {\headingfont\large #1\par}%
  \end{center}%
  \vfill\null
  \clearpage  % self-flush so the next poem starts fresh in either page mode
}

% Book/movement title page heading: large IM FELL, letterspaced
\newcommand{\booktitle}[1]{%
  {\headingfont\LARGE #1}%
}

% Internal movement label within a poem (e.g. a centered "I" / "II")
\newcommand{\movementlabel}[1]{%
  \vspace{0.5\baselineskip}%
  {\centering\headingfont #1\par}%
  \nopagebreak\vspace{0.3\baselineskip}%
  \noindent
}

% Half-title presenter line
\newcommand{\pressline}[1]{%
  {\headingfont\small #1\par}%
}

% Dedication/epigraph page: text high on page, right-of-center, italic
\newenvironment{dedicationpage}{%
  \thispagestyle{empty}%
  \null\vspace{0.22\textheight}%
  \begin{flushright}%
    \itshape
}{%
  \end{flushright}%
  \vfill\null
}

% Copyright page: block low on page, left-aligned, footnotesize
\newenvironment{copyrightpage}{%
  \thispagestyle{empty}%
  \null\vfill
  \footnotesize
  \setlength{\parskip}{0.5\baselineskip}%
  \setlength{\parindent}{0pt}%
}{%
  \null
}
