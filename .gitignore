# Python
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/
node_modules/
*.tsbuildinfo

# Local project data — tracked examples excepted
projects/*
!projects/spectra_poems/
# Fletcher series: the manuscript source (markdown, YAML configs, editorial
# docs, transcriptions) is irreplaceable hand work and MUST be versioned.
# The glob covers every volume project (fletcher-early-works, -dominant-works,
# -embattled-works, -falling-works), the shared fletcher-series/ root, and the
# transitional fletcher-complete-original-collections name during the split.
# Everything regenerable or binary stays out: the whole output/ tree and any
# page-scan images.  Re-add a specific binary deliberately if it must travel.
!projects/fletcher-*/
projects/fletcher-*/**/output/
projects/fletcher-*/**/*.png
projects/fletcher-*/**/*.jpg
projects/fletcher-*/**/*.jpeg
projects/fletcher-*/**/*.pdf
workspace.yaml

# LaTeX build artifacts (ephemeral)
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls
# Output directory: PDFs and metadata are ephemeral; tex files in output/tex/ are artifacts
**/output/*.pdf
**/output/*.xmpi
# output/tex/*.tex is intentionally NOT ignored — those are tracked artifacts
machinery/studio/backend/static/
machinery/studio/frontend/dist/

# Environment - local overrides only; .env.texgraph is tracked
.env
.env.local
.env.*.local
.env.texgraph.local
machinery/studio/backend/.env.studio

# OS
.DS_Store
Thumbs.db

# Local tooling state
.claude/
logs/
.ontology-baseline
