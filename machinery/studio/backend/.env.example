# Texgraph Studio backend — copy to .env.studio and fill in values
# Loaded automatically by pydantic-settings via app/core/config.py

# Path to the workspace root (where workspace.yaml lives)
# Defaults to current working directory if unset
WORKSPACE_ROOT=.

# Anthropic API key — required for Agent Chat / Wizard
ANTHROPIC_API_KEY=

# Studio server bind address (change if 8765 is taken)
HOST=127.0.0.1
PORT=8765
