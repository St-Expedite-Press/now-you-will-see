%# proof_fragment.tex.jinja2
%# Single content unit — no \documentclass, no \begin{document}.
%# Context: poem, section, config, rc, include_part_heading (bool)
%# Compile standalone: wrap with \documentclass{book}\input{../preamble}\begin{document}...\end{document}

%# ── Half-title ───────────────────────────────────────────────────────────────
\BLOCK{if poem.type == "halftitle"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
  {\normalfont\Large\itshape \VAR{config.title}\par}
\end{center}
\vspace*{\fill}
\clearpage

%# ── Title page ───────────────────────────────────────────────────────────────
\BLOCK{elif poem.type == "titlepage"}
\clearpage
\thispagestyle{empty}
\vspace*{2in}
\begin{center}
  {\normalfont\huge\itshape \VAR{config.title}\par}
  \BLOCK{if config.subtitle}
  \vspace{1.5ex}
  {\normalfont\normalsize \VAR{config.subtitle}\par}
  \BLOCK{endif}
  \vspace{2in}
  {\normalfont\normalsize\scshape\MakeLowercase{\VAR{config.author}}\par}
  \BLOCK{if config.publisher}
  \vfill
  {\normalfont\small \VAR{config.publisher}\par}
  \BLOCK{endif}
  {\normalfont\small \VAR{config.year}\par}
\end{center}
\clearpage

%# ── Copyright page ───────────────────────────────────────────────────────────
\BLOCK{elif poem.type == "copyright"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
{\small\setlength{\parskip}{0.75\baselineskip}\setlength{\parindent}{0pt}%
\BLOCK{for stanza in poem.stanzas}
\noindent
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\par
\BLOCK{if not loop.last}
\medskip
\BLOCK{endif}
\BLOCK{endfor}
}%
\clearpage

%# ── Table of contents ────────────────────────────────────────────────────────
\BLOCK{elif poem.type == "toc"}
\clearpage
\pagestyle{plain}
\tableofcontents
\clearpage
\pagestyle{empty}

%# ── Prose (introduction / backmatter chapter / in-section note) ──────────────
\BLOCK{elif poem.type == "prose"}
\BLOCK{if section.meta.get("type") in ["frontmatter", "backmatter"]}
\clearpage
\pagestyle{plain}
\chapter*{\VAR{poem.title}}
\addcontentsline{toc}{chapter}{\VAR{poem.title}}
\BLOCK{for stanza in poem.stanzas}
\BLOCK{for line in stanza}
\VAR{line}\par
\BLOCK{endfor}
\medskip
\BLOCK{endfor}
\clearpage
\BLOCK{if section.meta.get("type") == "frontmatter"}
\pagestyle{empty}
\BLOCK{else}
\pagestyle{fancy}
\BLOCK{endif}
\BLOCK{else}
\section*{\VAR{poem.title}}
\BLOCK{for stanza in poem.stanzas}
\BLOCK{for line in stanza}
\VAR{line}\par
\BLOCK{endfor}
\medskip
\BLOCK{endfor}
\BLOCK{endif}

%# ── Section / book title page ────────────────────────────────────────────────
\BLOCK{elif poem.type == "section-title"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
  {\normalfont\LARGE\itshape \VAR{section.meta.get("label") or section.title}\par}
  \BLOCK{if poem.meta.get("subtitle")}
  \vspace{1.5ex}
  {\normalfont\small \VAR{poem.meta.get("subtitle")}\par}
  \BLOCK{endif}
  \BLOCK{if poem.meta.get("note")}
  \vspace{4ex}
  {\normalfont\footnotesize\itshape \VAR{poem.meta.get("note")}\par}
  \BLOCK{endif}
\end{center}
\vspace*{\fill}
\clearpage
\markright{\VAR{section.meta.get("label") or section.title}}

%# ── Dedicatory poem (full poem, centered) ────────────────────────────────────
\BLOCK{elif poem.type == "dedicatory-poem"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
{\small\itshape \VAR{poem.title}\par}
\vspace{2ex}
\BLOCK{for stanza in poem.stanzas}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{if not loop.last}
\vspace{\VAR{rc.get("stanza_skip") or "1.2ex"}}
\BLOCK{endif}
\BLOCK{endfor}
\end{center}
\vspace*{\fill}
\clearpage

%# ── Dedication page (prose list) ─────────────────────────────────────────────
\BLOCK{elif poem.type == "dedication"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
{\small\itshape \VAR{poem.title}\par}
\vspace{2ex}
{\small\setlength{\parskip}{0.4\baselineskip}\setlength{\parindent}{0pt}%
\BLOCK{for stanza in poem.stanzas}
\BLOCK{for line in stanza.lines}
\VAR{line}\par
\BLOCK{endfor}
\BLOCK{if not loop.last}
\medskip
\BLOCK{endif}
\BLOCK{endfor}
}%
\end{center}
\vspace*{\fill}
\clearpage

%# ── Verse poem (regular, cycle, screenplay) ──────────────────────────────────
\BLOCK{else}

%# Part heading fires when this poem opens a new part
\BLOCK{if include_part_heading and poem.meta.get("part", "")}
\partheading{\VAR{poem.meta.get("part", "")}}
\BLOCK{endif}

\poemtitle{\VAR{poem.title}}
\BLOCK{if poem.subtitle}
{\itshape \VAR{poem.subtitle}}\nopagebreak\medskip
\BLOCK{endif}
\BLOCK{if poem.epigraph}
\begin{quote}\itshape
\VAR{poem.epigraph}
\BLOCK{if poem.epigraph_author}
\par\smallskip\hfill\upshape\small \VAR{poem.epigraph_author}
\BLOCK{endif}
\end{quote}
\BLOCK{endif}
\BLOCK{if poem.dedication}
\noindent\textit{\VAR{poem.dedication}}\par\medskip
\BLOCK{endif}

\BLOCK{if poem.is_cycle}
%# ── Poem cycle ───────────────────────────────────────────────────────────────
\BLOCK{for part in poem.parts}
\BLOCK{if part.title}
{\itshape \VAR{part.title}}\nopagebreak\medskip
\BLOCK{endif}
\BLOCK{for stanza in part.stanzas}
\BLOCK{if stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{\VAR{rc.get("stanza_skip") or "1.2ex"}}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{if not loop.last}
\medskip
\BLOCK{endif}
\BLOCK{endfor}

\BLOCK{elif poem.is_screenplay}
%# ── Poem screenplay ──────────────────────────────────────────────────────────
\BLOCK{for scene in poem.scenes}
\BLOCK{if not loop.first}
\medskip\noindent\rule{\linewidth}{0.4pt}\medskip
\BLOCK{endif}
\BLOCK{for stanza in scene.stanzas}
\BLOCK{if stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{\VAR{rc.get("stanza_skip") or "1.2ex"}}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endfor}

\BLOCK{else}
%# ── Standard verse poem ──────────────────────────────────────────────────────
\BLOCK{for stanza in poem.stanzas}
\BLOCK{if stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{\VAR{rc.get("stanza_skip") or "1.2ex"}}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

\BLOCK{endif}
