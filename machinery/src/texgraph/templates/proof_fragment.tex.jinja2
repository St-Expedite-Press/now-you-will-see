%# proof_fragment.tex.jinja2
%# Single content unit — no \documentclass, no \begin{document}.
%# Context: poem, section, config, rc, include_part_heading (bool)
%# Compile standalone: wrap with \documentclass{book}\input{../preamble}\begin{document}...\end{document}

%# ── Half-title ───────────────────────────────────────────────────────────────
\BLOCK{if poem.type == "halftitle"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
  {\headingfont\Large \VAR{config.title}\par}
\end{center}
\vspace*{\fill}
\clearpage

%# ── Title page ───────────────────────────────────────────────────────────────
\BLOCK{elif poem.type == "titlepage"}
\clearpage
\thispagestyle{empty}
\vspace*{2in}
\begin{center}
  {\headingfont\huge \VAR{config.title}\par}
  \BLOCK{if config.subtitle}
  \vspace{1.5ex}
  {\headingfont\normalsize \VAR{config.subtitle}\par}
  \BLOCK{endif}
  \vspace{2in}
  {\normalfont\normalsize\scshape\MakeLowercase{\VAR{config.author}}\par}
  \BLOCK{if config.publisher}
  \vfill
  {\headingfont\small \VAR{config.publisher}\par}
  \BLOCK{endif}
  {\normalfont\small \VAR{config.year}\par}
\end{center}
\clearpage

%# ── Copyright page ───────────────────────────────────────────────────────────
\BLOCK{elif poem.type == "copyright"}
\begin{copyrightpage}
\BLOCK{for stanza in poem.stanzas}
\noindent
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\par
\BLOCK{if not loop.last}
\medskip
\BLOCK{endif}
\BLOCK{endfor}
\end{copyrightpage}
\clearpage

%# ── Table of contents ────────────────────────────────────────────────────────
\BLOCK{elif poem.type == "toc"}
\clearpage
\pagestyle{plain}
\tableofcontents
\clearpage
\pagestyle{empty}

%# ── Prose (introduction / backmatter chapter / in-section note) ──────────────
\BLOCK{elif poem.type == "prose"}
\BLOCK{if section.meta.get("type") in ["frontmatter", "backmatter"]}
\chapter*{\VAR{poem.title}}
\addcontentsline{toc}{chapter}{\VAR{poem.title}}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.8\baselineskip}
\BLOCK{for stanza in poem.stanzas}
\BLOCK{for line in stanza}
\VAR{line}

\BLOCK{endfor}
\BLOCK{endfor}
\clearpage
\BLOCK{if section.meta.get("type") == "frontmatter"}
\pagestyle{empty}
\BLOCK{else}
\pagestyle{fancy}
\BLOCK{endif}
\BLOCK{else}
\section*{\VAR{poem.title}}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.6\baselineskip}
\BLOCK{for stanza in poem.stanzas}
\BLOCK{for line in stanza}
\VAR{line}

\BLOCK{endfor}
\BLOCK{endfor}
\BLOCK{endif}

%# ── Section / book title page ────────────────────────────────────────────────
\BLOCK{elif poem.type == "section-title"}
\cleardoublepage
\thispagestyle{empty}
\addcontentsline{toc}{chapter}{\VAR{section.meta.get("title") or section.title or poem.title}}
\vspace*{\fill}
\begin{center}
  \booktitle{\VAR{section.meta.get("title") or section.title or poem.title}}\par
  \BLOCK{if poem.meta.get("subtitle")}
  \vspace{2ex}
  {\headingfont\small \VAR{poem.meta.get("subtitle")}\par}
  \BLOCK{endif}
  \BLOCK{if poem.meta.get("note")}
  \vspace{4ex}
  {\normalfont\footnotesize\itshape \VAR{poem.meta.get("note")}\par}
  \BLOCK{endif}
\end{center}
\vspace*{\fill}
\clearpage

%# ── Dedicatory poem (full poem, centered) ────────────────────────────────────
\BLOCK{elif poem.type == "dedicatory-poem"}
\clearpage
\thispagestyle{empty}
\BLOCK{if poem.notes}\phantomsection\label{tg:note:\VAR{poem.note_id}}\BLOCK{endif}%
\vspace*{\fill}
\begin{center}
{\small\itshape \VAR{poem.title}\par}
\vspace{2ex}
\BLOCK{for stanza in poem.stanzas}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{if not loop.last}
\vspace{\interstanzaskip}
\BLOCK{endif}
\BLOCK{endfor}
\end{center}
\vspace*{\fill}
\clearpage

%# ── Dedication page (prose list) ─────────────────────────────────────────────
\BLOCK{elif poem.type == "dedication"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
{\small\itshape \VAR{poem.title}\par}
\vspace{2ex}
{\small\setlength{\parskip}{0.4\baselineskip}\setlength{\parindent}{0pt}%
\BLOCK{for stanza in poem.stanzas}
\BLOCK{for line in stanza.lines}
\VAR{line}\par
\BLOCK{endfor}
\BLOCK{if not loop.last}
\medskip
\BLOCK{endif}
\BLOCK{endfor}
}%
\end{center}
\vspace*{\fill}
\clearpage

%# ── Navigation/index files — no typeset content ──────────────────────────────
\BLOCK{elif poem.type in ["book-index", "collection-index", "section-index"]}
%# editorial index file — not typeset

%# ── Verse poem (regular, cycle, screenplay) ──────────────────────────────────
\BLOCK{else}

%# Full-page part divider fires when this poem opens a new part
\BLOCK{if include_part_heading and poem.meta.get("part", "")}
\partdivider{\VAR{poem.meta.get("part", "")}}
\BLOCK{endif}

%# One-per-page mode starts each poem on a fresh page (a \clearpage on an
%# already-fresh page is a no-op).  Flow mode (softcover) omits it so poems pack;
%# the poemblock supplies the inter-poem separation and break point.
\BLOCK{if rc.get("page_mode") != "flow"}\clearpage\BLOCK{endif}
%# Vertical placement is decided inside \begin{poemblock} by the poem's measured
%# height and the page mode.  See \NewEnviron{poemblock} in the preamble.
\begin{poemblock}
\BLOCK{if poem.meta.get("stanza_skip")}\setlength{\interstanzaskip}{\VAR{poem.meta.get("stanza_skip")}}\BLOCK{endif}%
\BLOCK{if poem.notes}\phantomsection\label{tg:note:\VAR{poem.note_id}}\BLOCK{endif}%
\poemtitle{\VAR{poem.title}}
\BLOCK{if poem.subtitle}
{\itshape \VAR{poem.subtitle}}\nopagebreak\medskip
\BLOCK{endif}
\BLOCK{if poem.epigraph}
\begin{quote}\itshape
\VAR{poem.epigraph}
\BLOCK{if poem.epigraph_author}
\par\smallskip\hfill\upshape\small \VAR{poem.epigraph_author}
\BLOCK{endif}
\end{quote}
\BLOCK{endif}
\BLOCK{if poem.dedication}
\noindent\textit{\VAR{poem.dedication}}\par\medskip
\BLOCK{endif}

\BLOCK{if poem.is_cycle}
%# ── Poem cycle ───────────────────────────────────────────────────────────────
\BLOCK{for part in poem.parts}
\BLOCK{if part.title}
{\itshape \VAR{part.title}}\nopagebreak\medskip
\BLOCK{endif}
\BLOCK{for stanza in part.stanzas}
\BLOCK{if stanza.is_movement}
\movementlabel{\VAR{stanza.label}}
\BLOCK{elif stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{\interstanzaskip}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{if not loop.last}
\medskip
\BLOCK{endif}
\BLOCK{endfor}

\BLOCK{elif poem.is_screenplay}
%# ── Poem screenplay ──────────────────────────────────────────────────────────
\BLOCK{for scene in poem.scenes}
\BLOCK{if not loop.first}
\medskip\noindent\rule{\linewidth}{0.4pt}\medskip
\BLOCK{endif}
\BLOCK{for stanza in scene.stanzas}
\BLOCK{if stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{\interstanzaskip}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endfor}

\BLOCK{else}
%# ── Standard verse poem ──────────────────────────────────────────────────────
\BLOCK{for stanza in poem.stanzas}
\BLOCK{if stanza.is_movement}
\movementlabel{\VAR{stanza.label}}
\BLOCK{elif stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{\interstanzaskip}
%# Bind the final stanza to the one before it so a flowing poem cannot orphan
%# its closing stanza alone at the top of a continuation page.
\BLOCK{if loop.revindex == 2}\nopagebreak[4]\BLOCK{endif}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

\end{poemblock}
%# Notes are not emitted inline — they are collected into the keyed back-matter
%# notes section per book (see render_notes_section / proof_notes template).

\BLOCK{endif}
