%# Texgraph - single-poem / poem-cycle / poem-screenplay LaTeX fragment
%# Used by LaTeXRenderer.render_poem() for previewing / testing.
%#
%# poem dict keys: title, subtitle, type, is_cycle, is_screenplay, cycle,
%#   cycle_part, epigraph, dedication, stanzas, parts, scenes, meta, path
\BLOCK{if poem.type == "section-title"}
\clearpage
\thispagestyle{empty}
\vspace*{\fill}
\begin{center}
  {\normalfont\LARGE\itshape \VAR{poem.title}}
\BLOCK{if poem.epigraph}

  \vspace{3\baselineskip}
  \begin{minipage}{0.55\textwidth}
    \setlength{\parindent}{0pt}
    \small\itshape
    \VAR{poem.epigraph}
\BLOCK{if poem.epigraph_author}
    \par\vspace{0.75\baselineskip}
    \normalfont\upshape\footnotesize\hfill \VAR{poem.epigraph_author}
\BLOCK{endif}
  \end{minipage}
\BLOCK{endif}
\end{center}
\vspace*{\fill}
\clearpage
\BLOCK{elif poem.type == "prose"}
%# ── Prose block ──────────────────────────────────────────────────────────────
\section*{\VAR{poem.title}}
\BLOCK{if poem.subtitle}
{\itshape \VAR{poem.subtitle}}\medskip
\BLOCK{endif}
\BLOCK{if poem.epigraph}
\begin{quote}\itshape
\VAR{poem.epigraph}
\BLOCK{if poem.epigraph_author}
\par\smallskip\hfill\upshape \VAR{poem.epigraph_author}
\BLOCK{endif}
\end{quote}
\BLOCK{endif}
\BLOCK{if poem.dedication}
\noindent\textit{\VAR{poem.dedication}}\medskip
\BLOCK{endif}
\BLOCK{for stanza in poem.stanzas}
\BLOCK{for line in stanza}
\VAR{line}\par
\BLOCK{endfor}
\BLOCK{endfor}
\BLOCK{elif poem.is_cycle}
%# ── Poem cycle (single-file) ─────────────────────────────────────────────────
\poemtitle{\VAR{poem.title}}
\BLOCK{if poem.subtitle}
{\itshape \VAR{poem.subtitle}}\medskip
\BLOCK{endif}
\BLOCK{if poem.epigraph}
\begin{quote}\itshape
\VAR{poem.epigraph}
\BLOCK{if poem.epigraph_author}
\par\smallskip\hfill\upshape \VAR{poem.epigraph_author}
\BLOCK{endif}
\end{quote}
\BLOCK{endif}
\BLOCK{if poem.dedication}
\noindent\textit{\VAR{poem.dedication}}\medskip
\BLOCK{endif}
\BLOCK{for part in poem.parts}
\BLOCK{if part.title}
{\itshape \VAR{part.title}}\nopagebreak\medskip
\BLOCK{endif}
\BLOCK{for stanza in part.stanzas}
\BLOCK{if stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{0.5\baselineskip}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{if not loop.last}
\medskip
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{elif poem.type == "poem-screenplay"}
%# ── Poem-screenplay interlude ───────────────────────────────────────────────
\poemtitle{\VAR{poem.title}}
\BLOCK{if poem.subtitle}
{\itshape \VAR{poem.subtitle}}\nopagebreak\medskip
\BLOCK{endif}
\BLOCK{if poem.epigraph}
\begin{quote}\itshape
\VAR{poem.epigraph}
\BLOCK{if poem.epigraph_author}
\par\smallskip\hfill\upshape \VAR{poem.epigraph_author}
\BLOCK{endif}
\end{quote}
\BLOCK{endif}
\BLOCK{if poem.dedication}
\noindent\textit{\VAR{poem.dedication}}\medskip
\BLOCK{endif}
\BLOCK{for scene in poem.scenes}
\BLOCK{if not loop.first}
\medskip\noindent\rule{\linewidth}{0.4pt}\medskip
\BLOCK{endif}
\BLOCK{for stanza in scene.stanzas}
\BLOCK{if stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{0.5\baselineskip}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endfor}
\BLOCK{else}
%# ── Regular poem ─────────────────────────────────────────────────────────────
\poemtitle{\VAR{poem.title}}
\BLOCK{if poem.subtitle}
{\itshape \VAR{poem.subtitle}}\nopagebreak\medskip
\BLOCK{endif}
\BLOCK{if poem.epigraph}
\begin{quote}\itshape
\VAR{poem.epigraph}
\BLOCK{if poem.epigraph_author}
\par\smallskip\hfill\upshape \VAR{poem.epigraph_author}
\BLOCK{endif}
\end{quote}
\BLOCK{endif}
\BLOCK{if poem.dedication}
\noindent\textit{\VAR{poem.dedication}}\medskip
\BLOCK{endif}
\BLOCK{for stanza in poem.stanzas}
\BLOCK{if stanza.is_blockquote}
\begin{quote}\itshape
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{quote}
\BLOCK{else}
\begin{verse}
\BLOCK{for line in stanza.lines}
\VAR{line}
\BLOCK{endfor}
\end{verse}
\BLOCK{endif}
\BLOCK{if not loop.last}
\vspace{0.5\baselineskip}
\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}
