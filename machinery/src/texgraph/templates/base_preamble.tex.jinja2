%# base_preamble.tex.jinja2
%# LuaLaTeX document preamble — generated by Texgraph
%# Variables: title, author, year, publisher, isbn, language, draft, document_id

\documentclass[12pt, openright, twoside]{book}

%# -----------------------------------------------------------------------
%# PDF/X-3 compliance (production only — omitted in draft mode)
%# -----------------------------------------------------------------------
{% if not draft %}
\usepackage[x-3]{pdfx}
{% endif %}

%# -----------------------------------------------------------------------
%# Fonts
%# -----------------------------------------------------------------------
\usepackage{fontspec}
\usepackage{unicode-math}

%# Prefer a system-installed Garamond; fall back to EB Garamond if absent.
\IfFontExistsTF{Garamond}{%
  \setmainfont{Garamond}[
    Ligatures      = TeX,
    Numbers        = OldStyle,
    ItalicFont     = Garamond Italic,
    BoldFont       = Garamond Bold,
  ]%
}{%
  \setmainfont{EB Garamond}[
    Ligatures      = TeX,
    Numbers        = OldStyle,
    ItalicFont     = EB Garamond Italic,
    BoldFont       = EB Garamond Bold,
  ]%
}

%# -----------------------------------------------------------------------
%# Language & quotes
%# -----------------------------------------------------------------------
\usepackage{polyglossia}
\setdefaultlanguage{{ "{" }}{{ language | default("english") }}{{ "}" }}

\usepackage[autostyle, english=american]{csquotes}

%# -----------------------------------------------------------------------
%# Microtypography
%# -----------------------------------------------------------------------
\usepackage[
  final,
  tracking   = true,
  kerning    = true,
  spacing    = true,
  factor     = 1100,
  stretch    = 10,
  shrink     = 10,
]{microtype}

%# -----------------------------------------------------------------------
%# Page geometry
%# -----------------------------------------------------------------------
\usepackage[
  inner  = 1.25in,
  outer  = 1.00in,
  top    = 1.00in,
  bottom = 1.00in,
  includeheadfoot,
]{geometry}

%# -----------------------------------------------------------------------
%# Line spacing
%# -----------------------------------------------------------------------
\usepackage{setspace}

%# -----------------------------------------------------------------------
%# Verse / poem typesetting
%# -----------------------------------------------------------------------
\usepackage{verse}

%# -----------------------------------------------------------------------
%# Running headers
%# -----------------------------------------------------------------------
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE]{\small\itshape {{ author }}}
\fancyhead[RO]{\small\itshape {{ title }}}
\fancyfoot[C]{\small\thepage}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

%# -----------------------------------------------------------------------
%# Hyperref / PDF metadata
%# -----------------------------------------------------------------------
\usepackage[
  pdfauthor   = {{ "{" }}{{ author }}{{ "}" }},
  pdftitle    = {{ "{" }}{{ title }}{{ "}" }},
  pdfsubject  = {{ "{" }}{{ title }}{{ "}" }},
  pdfkeywords = {{ "{" }}poetry{% if isbn %}, ISBN: {{ isbn }}{% endif %}{{ "}" }},
  pdfproducer = {LuaLaTeX / Texgraph},
  pdfcreator  = {Texgraph},
  pdfpagemode = UseNone,
  colorlinks  = false,
  hidelinks,
  unicode,
{% if draft %}
  draft,
{% endif %}
]{hyperref}

%# -----------------------------------------------------------------------
%# Custom commands
%# -----------------------------------------------------------------------

%# \poemtitle{<title>}
%# Renders a poem's title with consistent styling above the verse body.
\newcommand{\poemtitle}[1]{%
  \vspace{1.5\baselineskip}%
  {\noindent\normalfont\itshape\large #1}%
  \vspace{0.75\baselineskip}%
  \par\noindent
}

%# \stanzabreak
%# Inserts a visual break between stanzas (half-line of vertical space).
\newcommand{\stanzabreak}{%
  \vspace{0.5\baselineskip}%
}

