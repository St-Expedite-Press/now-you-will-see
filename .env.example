# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials.

# Anthropic API key (for Studio agent chat)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Studio server port (default: 8765)
# STUDIO_PORT=8765

# Workspace root for Texgraph projects (default: projects/ in repo root)
# WORKSPACE_ROOT=projects

# LuaLaTeX binary path (if not on PATH)
# LUALATEX_PATH=/usr/bin/lualatex

# OpenAI API key (for Hermes agent — set in hermes_agent/.env, not here)
# OPENAI_API_KEY=your_openai_key_here
